# Supabase Edge Functions Environment Variables
# These are set in: Supabase Dashboard → Project Settings → Edge Functions → Secrets
# Or locally via: supabase secrets set KEY=value

# These are auto-injected by Supabase runtime — you don't need to set them:
SUPABASE_URL=<auto-injected>
SUPABASE_ANON_KEY=<auto-injected>
SUPABASE_SERVICE_ROLE_KEY=<auto-injected>

# Set these manually in Supabase Dashboard:
GEMINI_API_KEY=                     # Google AI Studio: https://aistudio.google.com/app/apikey
GHL_API_KEY=                        # GoHighLevel: Settings → API Keys (Inner G's agency account)
GHL_LOCATION_ID=                    # Inner G's GHL Location ID
NEXT_PUBLIC_SITE_URL=https://agency.innergcomplete.com
