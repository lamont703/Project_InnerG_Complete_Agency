# Inner G Complete Agency — Client Intelligence Portal
# Environment Variables Reference
#
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git (it is in .gitignore).
#
# ─────────────────────────────────────────────────────────────
# REQUIRED — Core Supabase (always needed)
# ─────────────────────────────────────────────────────────────

# Your Supabase project URL
# Found at: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase anon/public key (safe to expose in browser)
# Found at: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────
# REQUIRED — Production site URL
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://agency.innergcomplete.com

# ─────────────────────────────────────────────────────────────
# SERVER-ONLY — Never prefix with NEXT_PUBLIC_
# These are NEVER bundled in browser JavaScript.
# Set these in Vercel Dashboard → Project → Environment Variables (for Next.js)
# and in Supabase Dashboard → Edge Functions → Secrets (for Edge Functions)
# ─────────────────────────────────────────────────────────────

# Supabase service role key — bypasses ALL RLS policies.
# Use ONLY in server-side code and Edge Functions.
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# GoHighLevel API Key — Inner G's internal agency account
# Get from: GHL Dashboard → Settings → Business Profile → API Keys
GHL_API_KEY=

# GoHighLevel Location ID — Inner G's agency sub-account location
GHL_LOCATION_ID=

# GoHighLevel Webhook Secret — for verifying inbound webhook signatures
GHL_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────
# PER-CLIENT (added on demand when a client integration is built)
# These follow the pattern: CLIENT_SLUG_VARIABLE_NAME
# ─────────────────────────────────────────────────────────────

# Example: Kane's Bookstore Instagram API
# KANES_INSTAGRAM_ACCESS_TOKEN=
# KANES_INSTAGRAM_ACCOUNT_ID=

# Example: Plenty of Hearts TikTok API
# POH_TIKTOK_ACCESS_TOKEN=
# POH_TIKTOK_REFRESH_TOKEN=
# POH_TIKTOK_OPEN_ID=
